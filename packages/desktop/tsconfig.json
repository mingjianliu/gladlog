{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vitest/globals", "node", "vite/client"],
    "resolveJsonModule": true
  },
  "include": ["src", "test", "dev", "qa"]
}
