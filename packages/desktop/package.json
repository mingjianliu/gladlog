{
  "name": "@gladlog/desktop",
  "version": "0.0.9",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:ui": "vite --config dev/vite.config.mts",
    "build": "electron-vite build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:vision": "tsx scripts/verifyVision.ts",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@gladlog/parser": "0.0.1",
    "d3-scale": "^4.0.2",
    "electron-log": "^5.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^4.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.gladlog.desktop",
    "productName": "gladlog",
    "electronVersion": "38.8.6",
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "afterSign": "build/afterSign.cjs",
    "extraResources": [
      {
        "from": "../corpus-tools/data/reference_vectors.json",
        "to": "reference_vectors.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
